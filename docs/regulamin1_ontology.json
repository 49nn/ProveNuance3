{
  "entity_types": [
    { "name": "CUSTOMER", "description": "Customer participating in an order, complaint, withdrawal, refund or chargeback." },
    { "name": "STORE", "description": "Merchant or online store handling the order." },
    { "name": "ORDER", "description": "Customer order placed in the store." },
    { "name": "PRODUCT", "description": "Physical or digital product contained in an order." },
    { "name": "PAYMENT", "description": "Payment transaction or payment instrument linked to an order." },
    { "name": "STATEMENT", "description": "Withdrawal statement submitted by the customer." },
    { "name": "RETURN_SHIPMENT", "description": "Shipment or proof of return linked to a withdrawal." },
    { "name": "ACCOUNT", "description": "Customer account in the store." },
    { "name": "CHARGEBACK", "description": "Payment dispute or chargeback procedure." },
    { "name": "COMPLAINT", "description": "Complaint concerning a product or service." },
    { "name": "FUNDS", "description": "Refunded funds or payout related to an order." },
    { "name": "COUPON", "description": "Coupon, promotion code or loyalty benefit." },
    { "name": "DATE", "description": "Calendar date represented as an entity-like identifier." }
  ],
  "predicates": [
    { "name": "CUSTOMER_HAS_ACCOUNT", "description": "Observable fact: a customer has a specific store account.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ACCOUNT", "entity_type": "ACCOUNT" }] },
    { "name": "ORDER_PLACED_BY", "description": "Observable fact: an order was placed by a customer.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "ORDER_CONFIRMED_BY_STORE", "description": "Observable fact: the store confirmed the order for execution.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "STORE", "entity_type": "STORE" }] },
    { "name": "ORDER_CONTAINS_PRODUCT", "description": "Observable fact: a product belongs to an order.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "ORDER_HAS_PAYMENT", "description": "Observable fact: an order is linked to a payment.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "PAYMENT", "entity_type": "PAYMENT" }] },
    { "name": "PAYMENT_NOT_MADE_WITHIN_48H", "description": "Observable fact: a prepaid order was not paid within 48 hours.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "PAYMENT_MARKED_HIGH_RISK", "description": "Observable fact: a payment was marked as high risk.", "roles": [{ "position": 0, "role": "PAYMENT", "entity_type": "PAYMENT" }] },
    { "name": "CUSTOMER_DATA_OBVIOUSLY_FALSE", "description": "Observable fact: the customer's data are incomplete or obviously false.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "STORE_EXPRESSLY_ACCEPTED_ORDER_DESPITE_DISPUTE", "description": "Observable fact: the store expressly accepted a new order despite an ongoing payment dispute.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "ITEM_DELIVERED_TO", "description": "Observable fact: a product was delivered to a customer on a given date.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 2, "role": "DATE", "entity_type": "DATE" }] },
    { "name": "WITHDRAWAL_STATEMENT_RECEIVED_ON", "description": "Observable fact: a withdrawal statement concerning an order was received on a given date.", "roles": [{ "position": 0, "role": "STATEMENT", "entity_type": "STATEMENT" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 2, "role": "ORDER", "entity_type": "ORDER" }, { "position": 3, "role": "DATE", "entity_type": "DATE" }] },
    { "name": "RETURN_SHIPMENT_SENT", "description": "Observable fact: the customer sent the returned goods or has evidence of return on a given date.", "roles": [{ "position": 0, "role": "RETURN_SHIPMENT", "entity_type": "RETURN_SHIPMENT" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }, { "position": 2, "role": "DATE", "entity_type": "DATE" }] },
    { "name": "DIGITAL_CONSENT_GIVEN", "description": "Observable fact: the customer expressly consented to starting digital performance before the withdrawal deadline.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "INFORMED_ABOUT_WITHDRAWAL_LOSS", "description": "Observable fact: the customer was informed about loss of the withdrawal right.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "DIGITAL_ACCESS_STARTED", "description": "Observable fact: delivery or access to a digital product started on a given date.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "PRODUCT", "entity_type": "PRODUCT" }, { "position": 2, "role": "DATE", "entity_type": "DATE" }] },
    { "name": "PRODUCT_IS_CUSTOM_MADE", "description": "Observable fact: a product was made to the customer's specification.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "PRODUCT_IS_HYGIENIC", "description": "Observable fact: a product is hygienic or sealed for health reasons.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "PRODUCT_IS_SEALED_MEDIA", "description": "Observable fact: a product is sealed audio, video or software media.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "PRODUCT_SEAL_OPENED", "description": "Observable fact: a sealed product package was opened after delivery.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "PRODUCT_IS_PERISHABLE", "description": "Observable fact: a product is perishable or has a short shelf life.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "PRODUCT_BECAME_INSEPARABLY_MIXED", "description": "Observable fact: after delivery the goods became inseparably mixed with other items.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "OFFER_GRANTS_BUSINESS_WITHDRAWAL", "description": "Observable fact: the store expressly granted a business customer a withdrawal right for a specific order.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "PRODUCT_DEFECTIVE", "description": "Observable fact: a product is defective or non-conforming.", "roles": [{ "position": 0, "role": "PRODUCT", "entity_type": "PRODUCT" }] },
    { "name": "STORE_AGREED_TO_COVER_RETURN_COST", "description": "Observable fact: the store agreed to cover the cost of return for an order.", "roles": [{ "position": 0, "role": "STORE", "entity_type": "STORE" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "CUSTOMER_NOT_INFORMED_ABOUT_RETURN_COST", "description": "Observable fact: the consumer was not informed about bearing the return cost.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "COMPLAINT_FILED", "description": "Observable fact: a complaint was filed by a customer concerning an order.", "roles": [{ "position": 0, "role": "COMPLAINT", "entity_type": "COMPLAINT" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 2, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "SHOP_DID_NOT_RESPOND_TO_COMPLAINT_IN_TIME", "description": "Observable fact: the store did not respond to a complaint within the relevant deadline.", "roles": [{ "position": 0, "role": "STORE", "entity_type": "STORE" }, { "position": 1, "role": "COMPLAINT", "entity_type": "COMPLAINT" }] },
    { "name": "PASSWORD_SHARED", "description": "Observable fact: login, password or activation key was shared with a third party.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "CHARGEBACK_OPENED_BY", "description": "Observable fact: a chargeback was opened by a customer.", "roles": [{ "position": 0, "role": "CHARGEBACK", "entity_type": "CHARGEBACK" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "CHARGEBACK_CONCERNS_PAYMENT", "description": "Observable fact: a chargeback concerns a particular payment.", "roles": [{ "position": 0, "role": "CHARGEBACK", "entity_type": "CHARGEBACK" }, { "position": 1, "role": "PAYMENT", "entity_type": "PAYMENT" }] },
    { "name": "CHARGEBACK_CONCERNS_ORDER", "description": "Observable fact: a chargeback concerns a particular order.", "roles": [{ "position": 0, "role": "CHARGEBACK", "entity_type": "CHARGEBACK" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "PAYMENT_PROVIDER_SUPPORTS_CHARGEBACK", "description": "Observable fact: the payment method or provider expressly allows chargeback for this payment.", "roles": [{ "position": 0, "role": "PAYMENT", "entity_type": "PAYMENT" }] },
    { "name": "REFUND_SENT", "description": "Observable fact: the store already sent a refund to the customer for an order.", "roles": [{ "position": 0, "role": "FUNDS", "entity_type": "FUNDS" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }, { "position": 2, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "DUPLICATE_REFUND_ATTEMPT", "description": "Observable fact: the customer is attempting to obtain a second refund for the same order.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "COUPON_APPLIED", "description": "Observable fact: a coupon was applied to an order.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "COUPON", "entity_type": "COUPON" }] },
    { "name": "COUPON_EXPIRED", "description": "Observable fact: a coupon has already expired.", "roles": [{ "position": 0, "role": "COUPON", "entity_type": "COUPON" }] },
    { "name": "ORDER_TOTAL_BELOW_COUPON_MIN", "description": "Observable fact: the order value is below the minimum required by the coupon terms.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "COUPON", "entity_type": "COUPON" }] },
    { "name": "AGREEMENT_FORMED", "description": "Derived legal conclusion: the sales agreement was formed.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "ORDER_MAY_BE_CANCELLED_FOR_NON_PAYMENT", "description": "Derived legal conclusion: the order may be cancelled because payment was not made in time.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "SHOP_MAY_REFUSE_ORDER", "description": "Derived legal conclusion: the store may refuse a new order from a customer.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "CUSTOMER_CAN_WITHDRAW", "description": "Derived legal conclusion: the customer can effectively withdraw from the order under the regulation.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "AB_CUSTOMER_CAN_WITHDRAW", "description": "Derived exception predicate: an explicit exception blocks the withdrawal right for the given customer and order.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "WITHDRAWAL_RIGHT_NOT_APPLICABLE", "description": "Derived legal conclusion: the withdrawal right does not apply.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "RETURN_COST_BORNE_BY_SHOP", "description": "Derived legal conclusion: the store bears the cost of return.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "RETURN_COST_BORNE_BY_CUSTOMER", "description": "Derived legal conclusion: the customer bears the cost of return.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "RETURN_SHIPMENT_SENT_FOR_ORDER", "description": "Derived helper predicate: there exists a return shipment or proof of return for the order.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "REFUND_ALREADY_SENT_FOR_ORDER", "description": "Derived helper predicate: a refund was already sent for the order.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "SHOP_CAN_WITHHOLD_REFUND", "description": "Derived legal conclusion: the store may withhold the refund until the goods or proof of shipment are received.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "COMPLAINT_DEEMED_ACCEPTED", "description": "Derived legal conclusion: the complaint is deemed accepted because the store did not respond in time.", "roles": [{ "position": 0, "role": "COMPLAINT", "entity_type": "COMPLAINT" }] },
    { "name": "SHOP_MAY_BLOCK_ACCOUNT", "description": "Derived legal conclusion: the store may block the customer's account.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "ACCOUNT_SHOULD_BE_UNBLOCKED", "description": "Derived legal conclusion: the customer account should be unblocked after the dispute was definitively resolved for the store.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "CHARGEBACK_NOT_APPLICABLE", "description": "Derived legal conclusion: chargeback does not apply to the payment under the regulation.", "roles": [{ "position": 0, "role": "CHARGEBACK", "entity_type": "CHARGEBACK" }, { "position": 1, "role": "PAYMENT", "entity_type": "PAYMENT" }] },
    { "name": "FUNDS_RETURNED_TO_CUSTOMER", "description": "Derived legal conclusion: funds are treated as returned to the customer.", "roles": [{ "position": 0, "role": "ORDER", "entity_type": "ORDER" }, { "position": 1, "role": "CUSTOMER", "entity_type": "CUSTOMER" }] },
    { "name": "DOUBLE_REFUND_NOT_DUE", "description": "Derived legal conclusion: a second full refund is not due for the same order.", "roles": [{ "position": 0, "role": "CUSTOMER", "entity_type": "CUSTOMER" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] },
    { "name": "COUPON_NOT_APPLICABLE", "description": "Derived legal conclusion: the coupon cannot be effectively applied to the order.", "roles": [{ "position": 0, "role": "COUPON", "entity_type": "COUPON" }, { "position": 1, "role": "ORDER", "entity_type": "ORDER" }] }
  ],
  "clusters": [
    { "name": "customer_type", "entity_type": "CUSTOMER", "entity_role": "CUSTOMER", "value_role": "TYPE", "domain": ["CONSUMER", "BUSINESS"], "description": "Type of customer relevant for withdrawal and complaint rules." },
    { "name": "product_type", "entity_type": "PRODUCT", "entity_role": "PRODUCT", "value_role": "TYPE", "domain": ["PHYSICAL", "DIGITAL"], "description": "Type of product relevant for delivery and digital-performance rules." },
    { "name": "payment_method", "entity_type": "PAYMENT", "entity_role": "PAYMENT", "value_role": "METHOD", "domain": ["CARD", "TRANSFER", "BLIK", "COD"], "description": "Payment method used in the order." },
    { "name": "account_status", "entity_type": "ACCOUNT", "entity_role": "ACCOUNT", "value_role": "STATUS", "domain": ["ACTIVE", "BLOCKED"], "description": "Current status of the customer account." },
    { "name": "chargeback_status", "entity_type": "CHARGEBACK", "entity_role": "CHARGEBACK", "value_role": "STATUS", "domain": ["OPEN", "RESOLVED_CUSTOMER", "RESOLVED_STORE"], "description": "Current status of a chargeback dispute." }
  ],
  "rules": [
    { "rule_id": "core.agreement_formed", "module": "core", "head": { "predicate": "agreement_formed", "args": [{ "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_confirmed_by_store", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "STORE", "term": { "var": "S" } }] }] },
    { "rule_id": "core.order_may_be_cancelled_for_non_payment", "module": "core", "head": { "predicate": "order_may_be_cancelled_for_non_payment", "args": [{ "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "payment_not_made_within_48h", "args": [{ "role": "ORDER", "term": { "var": "O" } }] }] },
    { "rule_id": "core.shop_may_refuse_order_blocked_account", "module": "core", "head": { "predicate": "shop_may_refuse_order", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "customer_has_account", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ACCOUNT", "term": { "var": "A" } }] }, { "literal_type": "pos", "predicate": "account_status", "args": [{ "role": "ACCOUNT", "term": { "var": "A" } }, { "role": "STATUS", "term": { "const": "blocked" } }] }] },
    { "rule_id": "core.shop_may_refuse_order_open_chargeback", "module": "core", "head": { "predicate": "shop_may_refuse_order", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "chargeback_opened_by", "args": [{ "role": "CHARGEBACK", "term": { "var": "CB" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "chargeback_status", "args": [{ "role": "CHARGEBACK", "term": { "var": "CB" } }, { "role": "STATUS", "term": { "const": "open" } }] }, { "literal_type": "naf", "predicate": "store_expressly_accepted_order_despite_dispute", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }] },
    { "rule_id": "core.shop_may_refuse_order_high_risk_payment", "module": "core", "head": { "predicate": "shop_may_refuse_order", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "order_has_payment", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "PAYMENT", "term": { "var": "P" } }] }, { "literal_type": "pos", "predicate": "payment_marked_high_risk", "args": [{ "role": "PAYMENT", "term": { "var": "P" } }] }] },
    { "rule_id": "core.shop_may_refuse_order_false_data", "module": "core", "head": { "predicate": "shop_may_refuse_order", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "customer_data_obviously_false", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }] }] },
    { "rule_id": "exceptions.ab_customer_can_withdraw_business", "module": "exceptions", "head": { "predicate": "ab_customer_can_withdraw", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "customer_type", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "TYPE", "term": { "const": "business" } }] }, { "literal_type": "naf", "predicate": "offer_grants_business_withdrawal", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }] },
    { "rule_id": "exceptions.ab_customer_can_withdraw_custom_made", "module": "exceptions", "head": { "predicate": "ab_customer_can_withdraw", "args": [{ "role": "CUSTOMER", "term": { "var": "C" } }, { "role": "ORDER", "term": { "var": "O" } }] }, "body": [{ "literal_type": "pos", "predicate": "order_placed_by", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "CUSTOMER", "term": { "var": "C" } }] }, { "literal_type": "pos", "predicate": "order_contains_product", "args": [{ "role": "ORDER", "term": { "var": "O" } }, { "role": "PRODUCT", "term": { "var": "P" } }] }, { "literal_type": "pos", "predicate": "product_is_custom_made", "args": [{ "role": "PRODUCT", "term": { "var": "P" } }] }] },
