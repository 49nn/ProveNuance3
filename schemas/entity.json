{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/nesy/schemas/entity.schema.json",
  "title": "Entity",
  "type": "object",
  "additionalProperties": false,
  "required": ["entity_id", "type", "canonical_name", "created_at"],
  "properties": {
    "entity_id":      { "type": "string", "minLength": 1 },
    "type":           { "type": "string", "minLength": 1 },
    "canonical_name": { "type": "string", "minLength": 1 },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "embedding_ref": { "type": "string" },
    "created_at":    { "type": "string", "format": "date-time" },
    "updated_at":    { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/ProvenanceItem" }
    },
    "memory_slots": {
      "type": "object",
      "description": "Per-slot versioned values for instance-specific attributes (name/address/phone/...).",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value"],
          "properties": {
            "value":      { "description": "Dowolna wartość slotu (string, number, object)" },
            "normalized": { "description": "Opcjonalna znormalizowana forma wartości" },
            "valid_from": { "type": ["string", "null"], "format": "date-time" },
            "valid_to":   { "type": ["string", "null"], "format": "date-time" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "source_rank":{ "type": "number", "minimum": 0, "maximum": 1 },
            "provenance": {
              "type": "array",
              "items": { "$ref": "common.schema.json#/$defs/ProvenanceItem" }
            }
          }
        }
      }
    },
    "linking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blocking_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_linked_from": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/ID" }
        }
      }
    }
  }
}
